<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" maxHeight="720.0" maxWidth="1280.0" minHeight="-Infinity" minWidth="-Infinity" prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controllers.HomeController">
    <children>
        <VBox layoutX="0.0" layoutY="0.0" prefHeight="720.0" prefWidth="1280.0">
            <children>
                <Label alignment="TOP_CENTER" contentDisplay="CENTER" prefHeight="128.0" prefWidth="1284.0" text="Dictionary" textAlignment="CENTER" textOverrun="ELLIPSIS">
                    <font>
                        <Font name="System Bold" size="30.0" />
                    </font>
                </Label>
                <VBox alignment="BASELINE_CENTER" prefHeight="149.0" prefWidth="600.0" spacing="40.0">
                    <children>
                        <Button fx:id="learningBtn" mnemonicParsing="false" prefHeight="32.0" prefWidth="236.0" text="Học từ vựng" onAction="#onOfflineButtonClick"/>
                        <Button fx:id="playGameBtn" mnemonicParsing="false" prefHeight="32.0" prefWidth="236.0" text="Chơi game" onAction="#onGameButton"/>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
